# BMU Wi-Fi Auto-Login — credentials template
# Copy this to credentials.ini and fill in your details,
# OR just run:  python bmu_wifi.py --setup

[portal]
# The login endpoint (leave as-is for BMU)
login_url = https://bmunet.bmu.edu.in:8090/login.xml
# Used to detect real internet vs captive portal
check_url = http://connectivitycheck.gstatic.com/generate_204

[credentials]
# Your primary BMU portal username and password
username = your.name.23cse
password = YourPassword

# Optional: secondary/backup credentials
# If primary login fails (wrong password / expired), these are tried automatically.
# Remove this section if you don't need a backup account.
[secondary]
username = alt.name.23cse
password = AltPassword
